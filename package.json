{
  "name": "finances-backend",
  "version": "0.1.0",
  "description": "Local-first backend for syncing bank accounts, balances, and transactions via Plaid, with a YubiKey-gated secrets vault.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "vault": "tsx src/cli/vault-cli.ts",
    "seed": "tsx src/cli/seed-cli.ts",
    "notify": "tsx src/cli/notify-cli.ts",
    "web:dev": "npm --prefix web run dev",
    "web:build": "npm --prefix web run build",
    "test": "vitest run"
  },
  "dependencies": {
    "@google/adk": "^1.3.0",
    "@google/genai": "^2.10.0",
    "better-sqlite3": "^11.3.0",
    "commander": "^12.1.0",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "plaid": "^32.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "tsx": "^4.19.1",
    "typescript": "^5.6.3",
    "vitest": "^4.1.9"
  }
}
