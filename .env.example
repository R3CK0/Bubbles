# All of this is non-secret runtime config. Actual Plaid keys and bank access
# tokens are NEVER put in .env — they live only in the YubiKey-gated vault
# (see README.md). Copy this to .env if you want to override defaults.

PORT=4000
HOST=127.0.0.1

# Where the vault + SQLite DB live. Defaults to ./data
# FINANCES_DATA_DIR=./data

PLAID_COUNTRY_CODES=CA
PLAID_LANGUAGE=en
PLAID_PRODUCTS=transactions

# Gemini key for the AI expense-review assistant (Budget → Inbox). Optional:
# without it the inbox falls back to history-based suggestions only.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.5-flash
# Client-side throttle. Free tier allows 10 requests/min — the default of 8
# stays under it. On a paid tier (150+ RPM) raise this.
# GEMINI_RPM=8
