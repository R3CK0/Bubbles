# All of this is non-secret runtime config. Actual Plaid keys and bank access
# tokens are NEVER put in .env — they live only in the YubiKey-gated vault
# (see README.md). Copy this to .env if you want to override defaults.

PORT=4000
HOST=127.0.0.1

# Where the vault + SQLite DB live. Defaults to ./data
# FINANCES_DATA_DIR=./data

PLAID_COUNTRY_CODES=CA
PLAID_LANGUAGE=en
PLAID_PRODUCTS=transactions

# Gemini key for the AI expense-review assistant (Budget → Inbox). Optional:
# without it the inbox falls back to history-based suggestions only.
GEMINI_API_KEY=
# GEMINI_MODEL=gemini-3.5-flash
# Client-side throttle. Free tier allows 10 requests/min — the default of 8
# stays under it. On a paid tier (150+ RPM) raise this.
# GEMINI_RPM=8

# Telegram push notifications for failed bank syncs. Optional: leave blank to
# disable. Both are required to enable it.
#   1. Message @BotFather on Telegram, /newbot, and copy the token it gives.
#   2. Put the token in TELEGRAM_BOT_TOKEN below, then message your new bot
#      anything in Telegram and run:  npm run notify -- chat-id
#      That prints the chat id to paste into TELEGRAM_CHAT_ID.
#   3. Verify end-to-end with:  npm run notify -- test
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Live market data. Yahoo Finance is the keyless primary (symbol search, live
# quotes, daily closes, option chains) — no key needed. Finnhub is an OPTIONAL
# fallback used only when Yahoo errors: get a free key (60 req/min) at
# finnhub.io and set it here to enable it.
FINNHUB_API_KEY=
# Intraday portfolio refresh cadence in minutes (self-gated to market hours).
# Set to 0 to disable live intraday refresh entirely. Default 5.
# FINANCES_INTRADAY_MINUTES=5
